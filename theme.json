      "lineHeight": "1.7"
    },
    "elements": {
      "heading": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--display)",
          "fontWeight": "500",
          "letterSpacing": "-0.01em"
        },
        "color": {
          "text": "var(--wp--preset--color--ink-900)"
        }
      },
      "h1": {
        "typography": {
          "fontSize": "var(--wp--preset--font-size--4-xl)",
          "lineHeight": "1.08"
        }
      },
      "h2": {
