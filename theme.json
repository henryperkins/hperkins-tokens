          "fontSize": "var(--wp--preset--font-size--xl)",
          "lineHeight": "1.22"
        }
      },
      "h5": {
        "typography": {
          "fontSize": "var(--wp--preset--font-size--lg)",
          "lineHeight": "1.22"
        }
      },
      "h6": {
        "typography": {
          "fontSize": "var(--wp--preset--font-size--md)",
          "lineHeight": "1.22"
        }
      },
      "link": {
        "color": {
          "text": "var(--wp--preset--color--green-700)"
        },
        ":hover": {
          "color": {
            "text": "var(--wp--preset--color--gold-700)"
          }
        }
      }
    },
    "spacing": {
      "blockGap": "var(--wp--preset--spacing--5)",
      "padding": {
        "top": "0",
        "bottom": "0",
        "left": "var(--wp--preset--spacing--6)",
        "right": "var(--wp--preset--spacing--6)"
      }
